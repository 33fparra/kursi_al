---
import Base from '../../../layouts/Base.astro';
import MortgageCalc from '../../../components/MortgageCalc';
import { t } from '../../../lib/i18n';
import albaniaData from '../../../data/albania.json';

export const prerender = true;
const lang = 'en' as const;
const banks = albaniaData.banks as any[];
const lastUpdatedAL = (albaniaData as any)["_____LAST_UPDATE_DATE_____"] ?? null;
---
<Base
  title="Albania Mortgage Calculator — Monthly Payment & Total Cost | leku.al"
  description="Calculate monthly mortgage payments for Albanian banks. Rates from 5.5% per year. Compare Raiffeisen, BKT, OTP Bank and Tirana Bank."
  keywords="Albania mortgage calculator, Albanian mortgage rates, mortgage payment Albania, home loan Albania, Raiffeisen mortgage Albania"
  lang={lang}
  currentPath="/albania/hipoteka"
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/en/albania/" class="breadcrumb-link"><span class="fi fi-al" aria-hidden="true"></span> Albania</a>
    <i class="ti ti-chevron-right breadcrumb-sep" aria-hidden="true"></i>
    <span class="breadcrumb-current">{t(lang, 'country.mortgage')}</span>
  </nav>

  <div class="section-header">
    <h1 class="page-title">{t(lang, 'mortgage.title')}</h1>
    <p class="page-subtitle">{t(lang, 'mortgage.subtitle.al')}</p>
    <p class="page-intro">Albanian mortgages are available in ALL and EUR. Annual rates range from 5.5% to 6.5% depending on the bank and term. Calculate monthly payments and total cost before deciding.</p>
  </div>

  <MortgageCalc client:load banks={banks} currency="ALL" lang={lang} />

  <section class="faq-section">
    <h2 class="faq-title">{t(lang, 'mortgage.faq.title')}</h2>
    <dl class="faq-list">
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'mortgage.faq.q1')}</dt>
        <dd class="faq-answer">{t(lang, 'mortgage.faq.a1')}</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'mortgage.faq.q2')}</dt>
        <dd class="faq-answer">{t(lang, 'mortgage.faq.a2')}</dd>
      </div>
    </dl>
  </section>
  
  <p class="page-last-updated">
    <i class="ti ti-refresh" aria-hidden="true"></i>
    {lastUpdatedAL}
  </p>
</Base>
