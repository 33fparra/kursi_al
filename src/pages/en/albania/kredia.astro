---
import Base from '../../../layouts/Base.astro';
import LoanCalc from '../../../components/LoanCalc';
import { t } from '../../../lib/i18n';
import albaniaData from '../../../data/albania.json';
export const prerender = true;
const lang = 'en' as const;
const banks = albaniaData.banks as any[];
const lastUpdatedAL = (albaniaData as any)["_____LAST_UPDATE_DATE_____"] ?? null;
---
<Base title="Albania Personal Loan Calculator | leku.al" description="Calculate monthly payments for personal loans in Albania. Rates from 11.9% per year." lang={lang} currentPath="/albania/kredia/">
  <div class="section-header">
    <h1 class="page-title">{t(lang, 'loan.title')}</h1>
    <p class="page-subtitle">{t(lang, 'loan.subtitle.al')}</p>
  </div>
  <LoanCalc client:load banks={banks} currency="ALL" lang={lang} />
  <section class="faq-section">
    <h2 class="faq-title">{t(lang, 'loan.faq.title')}</h2>
    <dl class="faq-list">
      <div class="faq-item"><dt class="faq-question">{t(lang, 'loan.faq.q1')}</dt><dd class="faq-answer">{t(lang, 'loan.faq.a1')}</dd></div>
      <div class="faq-item"><dt class="faq-question">{t(lang, 'loan.faq.q2')}</dt><dd class="faq-answer">{t(lang, 'loan.faq.a2')}</dd></div>
    </dl>
  </section>
  
  <p class="page-last-updated">
    <i class="ti ti-refresh" aria-hidden="true"></i>
    {lastUpdatedAL}
  </p>
</Base>
