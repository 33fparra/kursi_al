---
import Base from '../../../layouts/Base.astro';
import SalaryCalc from '../../../components/SalaryCalc';
import { t } from '../../../lib/i18n';
import albaniaData from '../../../data/albania.json';

export const prerender = true;
const lang = 'en' as const;
const { salary } = albaniaData;
const professions = albaniaData.professions as any[];
---
<Base
  title="Albania Salary Calculator — Gross to Net 2025 | leku.al"
  description="Calculate net salary from gross using Albania's tax system. See average salaries by profession: doctor, engineer, IT developer and more. Min wage: 45,000 L."
  keywords="Albania salary calculator, gross to net Albania, Albania income tax, Albania minimum wage, Albania average salary by profession"
  lang={lang}
  currentPath="/albania/paga"
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/en/albania/" class="breadcrumb-link"><span class="fi fi-al" aria-hidden="true"></span> Albania</a>
    <i class="ti ti-chevron-right breadcrumb-sep" aria-hidden="true"></i>
    <span class="breadcrumb-current">{t(lang, 'country.salary')}</span>
  </nav>

  <div class="section-header">
    <h1 class="page-title">{t(lang, 'salary.title')}</h1>
    <p class="page-subtitle">{t(lang, 'salary.subtitle.al')}</p>
  </div>

  <SalaryCalc client:load country="al" currency="ALL" lang={lang} minWage={salary.minWage} avgWage={salary.avgWage} professions={professions} />

  <div class="tax-brackets-card">
    <h2 class="tax-brackets-title">Tax brackets (monthly) — Albania</h2>
    <p style="font-size: var(--text-xs); color: var(--ink-muted); margin-bottom: var(--space-3);">Progressive income tax + 9.5% social security + 1.7% health</p>
    <div class="tax-brackets-list">
      {salary.brackets.map(b => (
        <div class="tax-bracket-row">
          <span class="tax-bracket-range">{b.from.toLocaleString('en')} – {b.to ? b.to.toLocaleString('en') : '∞'} L</span>
          <span class={`tax-bracket-rate tax-bracket-rate--${b.rate === 0 ? 'zero' : b.rate < 0.2 ? 'mid' : 'high'}`}>{b.label}</span>
        </div>
      ))}
    </div>
  </div>

  <section class="faq-section">
    <h2 class="faq-title">{t(lang, 'salary.faq.title')}</h2>
    <dl class="faq-list">
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'salary.faq.q1.al')}</dt>
        <dd class="faq-answer">{t(lang, 'salary.faq.a1.al')}</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'salary.faq.q2.al')}</dt>
        <dd class="faq-answer">{t(lang, 'salary.faq.a2.al')}</dd>
      </div>
    </dl>
  </section>
</Base>
