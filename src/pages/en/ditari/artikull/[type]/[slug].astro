---
import Base from '../../../../../layouts/Base.astro';
import { t } from '../../../../../lib/i18n';
import { getCollection, render } from 'astro:content';

export const prerender = true;
const lang = 'en' as const;

export async function getStaticPaths() {
  const entries = await getCollection('ditari', e => e.data.lang === 'en');
  return entries.map(entry => ({
    params: { type: entry.data.type, slug: entry.id.split('/').pop()!.replace(/^\d{4}-\d{2}-\d{2}-/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, description, type, category, date, image, imageAlt, readMinutes, author, coAuthor } = entry.data;
const { Content } = await render(entry);

const slug = entry.id.split('/').pop()!.replace(/^\d{4}-\d{2}-\d{2}-/, '');
const sqEntries = await getCollection('ditari', e => e.data.lang === 'sq' && e.data.type === type);
// Match by translationKey (not slug) so EN/SQ pairs with different filenames link correctly
const sqMatch = sqEntries.find(e => e.data.translationKey === entry.data.translationKey);
const allowedLangs: ('sq' | 'en')[] | null = ['sq', 'en'];
const langLinks = {
  en: `/en/ditari/artikull/${type}/${slug}/`,
  sq: sqMatch ? `/ditari/artikull/${type}/${sqMatch.id.split('/').pop()!.replace(/^\d{4}-\d{2}-\d{2}-/, '')}/` : '/ditari/',
};

const dateLabel = date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const typeLabel = type === 'edukim' ? t(lang, 'ditari.typeEdukim') : t(lang, 'ditari.typeLajme');

const articleJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': type === 'lajme' ? 'NewsArticle' : 'Article',
  headline: title,
  description,
  image: `https://leku.al${image}`,
  datePublished: date.toISOString(),
  inLanguage: 'en',
  publisher: {
    '@type': 'Organization',
    name: 'leku.al',
    url: 'https://leku.al',
  },
});

// Extract FAQ pairs from <details>/<summary> blocks in the article body
const faqRegex = /<summary[^>]*><b>([\s\S]*?)<\/b><\/summary>([\s\S]*?)<\/details>/gi;
const faqItems: { question: string; answer: string }[] = [];
let faqMatch;
while ((faqMatch = faqRegex.exec(entry.body || '')) !== null) {
  const question = faqMatch[1].trim();
  const answer = faqMatch[2]
    .replace(/<br\s*\/?>/gi, ' ')
    .replace(/<[^>]+>/g, '')
    .replace(/\s+/g, ' ')
    .trim();
  if (question && answer) faqItems.push({ question, answer });
}

const faqJsonLd = faqItems.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
}) : null;
---
<Base
  title={`${title} | leku.al`}
  description={description}
  lang={lang}
  currentPath="/en/ditari/"
  ogImage={image}
  ogType="article"
  allowedLangs={allowedLangs}
  langLinks={langLinks}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleJsonLd} />
    {faqJsonLd && <script type="application/ld+json" set:html={faqJsonLd} />}
  </Fragment>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/en/ditari/" class="breadcrumb-link">{t(lang, 'ditari.heading')}</a>
    <i class="ti ti-chevron-right breadcrumb-sep" aria-hidden="true"></i>
    <span class="breadcrumb-current">{category}</span>
  </nav>

  <article class="blog-post">
    <header class="blog-post-header">
      <div class="blog-post-meta">
        <span class={`ditari-badge ditari-badge--${type}`} style="position: static;">{typeLabel}</span>
        <span class="blog-category">{category}</span>
        <span class="blog-date">{dateLabel}</span>
        <span class="blog-read">{readMinutes} {t(lang, 'ditari.minRead')}</span>
      </div>
      <h1 class="blog-post-title">{title}</h1>
      {author && (
        <div class="article-byline">
          <a href="/en/rreth-autorit/fa-parretti/" class="article-byline-author">
            <i class="ti ti-user-circle" aria-hidden="true"></i>
            {author}
          </a>
          {coAuthor && (
            <span class="article-byline-coauthor">
              <i class="ti ti-users" aria-hidden="true"></i>
              {coAuthor}
            </span>
          )}
        </div>
      )}
      <p class="blog-post-desc">{description}</p>
    </header>

    <img src={image} alt={imageAlt} class="ditari-article-img" />

    <div class="ditari-content">
      <Content />
    </div>

    {author && (
      <div class="article-author-footer">
        <div class="article-author-card">
          <i class="ti ti-user-circle article-author-icon" aria-hidden="true"></i>
          <div>
            <a href="/en/rreth-autorit/fa-parretti/" class="article-author-name">{author}</a>
            {coAuthor && <p class="article-author-coname">{coAuthor}</p>}
          </div>
        </div>
      </div>
    )}

    <footer class="blog-post-footer">
      <a href="/en/ditari/" class="tool-nav-link">
        <i class="ti ti-arrow-left" aria-hidden="true"></i> {t(lang, 'ditari.backToList')}
      </a>
    </footer>
  </article>
</Base>
