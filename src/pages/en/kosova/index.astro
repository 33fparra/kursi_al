---
import Base from '../../../layouts/Base.astro';
import { t } from '../../../lib/i18n';
import kosovoData from '../../../data/kosovo.json';

export const prerender = true;
const lang = 'en' as const;
const d = kosovoData;
---
<Base
  title="Kosovo — Banks, Mortgages, Loans and Salaries | leku.al"
  description="Compare Kosovo's banks, calculate mortgages and loans in euros, and see salaries by profession. Financial tools for Kosovo."
  keywords="Kosovo banks, Kosovo mortgage, Kosovo loan, Kosovo salary, interest rates Kosovo, Raiffeisen Kosovo, ProCredit Kosovo"
  lang={lang}
  currentPath="/kosova"
>
  <div class="country-hero">
    <div class="country-hero-flag"><span class="fi fi-xk" aria-hidden="true"></span></div>
    <div class="country-hero-text">
      <h1 class="country-hero-title">{t(lang, 'hub.xk.title')}</h1>
      <p class="country-hero-sub">{t(lang, 'hub.xk.subtitle')}</p>
    </div>
  </div>

  <div class="country-facts">
    <div class="country-fact"><span class="country-fact-label">Currency</span><span class="country-fact-value">Euro (EUR)</span></div>
    <div class="country-fact"><span class="country-fact-label">Minimum wage</span><span class="country-fact-value">€400/month</span></div>
    <div class="country-fact"><span class="country-fact-label">Banks</span><span class="country-fact-value">{d.banks.length} banks</span></div>
    <div class="country-fact"><span class="country-fact-label">Avg mortgage rate</span><span class="country-fact-value">~4.5–5.5%/yr</span></div>
  </div>

  <section class="hub-tools" aria-label="Financial tools">
    <h2 class="hub-tools-title">Financial tools</h2>
    <div class="hub-grid">
      <a href="/en/kosova/banks" class="hub-card">
        <div class="hub-card-icon"><i class="ti ti-building-bank" aria-hidden="true"></i></div>
        <div class="hub-card-body">
          <h3 class="hub-card-title">{t(lang, 'hub.tools.banks')}</h3>
          <p class="hub-card-desc">{t(lang, 'hub.tools.banks.desc')}</p>
          <p class="hub-card-meta">{d.banks.length} banks · EUR rates</p>
        </div>
        <i class="ti ti-chevron-right hub-card-arrow" aria-hidden="true"></i>
      </a>
      <a href="/en/kosova/mortgage" class="hub-card">
        <div class="hub-card-icon hub-card-icon--green"><i class="ti ti-home" aria-hidden="true"></i></div>
        <div class="hub-card-body">
          <h3 class="hub-card-title">{t(lang, 'hub.tools.mortgage')}</h3>
          <p class="hub-card-desc">{t(lang, 'hub.tools.mortgage.desc')}</p>
          <p class="hub-card-meta">From 4.50% per year</p>
        </div>
        <i class="ti ti-chevron-right hub-card-arrow" aria-hidden="true"></i>
      </a>
      <a href="/en/kosova/loan" class="hub-card">
        <div class="hub-card-icon hub-card-icon--blue"><i class="ti ti-credit-card" aria-hidden="true"></i></div>
        <div class="hub-card-body">
          <h3 class="hub-card-title">{t(lang, 'hub.tools.loan')}</h3>
          <p class="hub-card-desc">{t(lang, 'hub.tools.loan.desc')}</p>
          <p class="hub-card-meta">From 9.50% per year</p>
        </div>
        <i class="ti ti-chevron-right hub-card-arrow" aria-hidden="true"></i>
      </a>
      <a href="/en/kosova/salary" class="hub-card">
        <div class="hub-card-icon hub-card-icon--orange"><i class="ti ti-wallet" aria-hidden="true"></i></div>
        <div class="hub-card-body">
          <h3 class="hub-card-title">{t(lang, 'hub.tools.salary')}</h3>
          <p class="hub-card-desc">{t(lang, 'hub.tools.salary.desc')}</p>
          <p class="hub-card-meta">Min: €400 · {d.professions.length} professions</p>
        </div>
        <i class="ti ti-chevron-right hub-card-arrow" aria-hidden="true"></i>
      </a>
    </div>
  </section>

  <section class="hub-converter-links">
    <a href="/en/" class="hub-conv-link"><i class="ti ti-arrows-up-down" aria-hidden="true"></i>{t(lang, 'hub.converter.link')}</a>
    <a href="/en/remitanca" class="hub-conv-link"><i class="ti ti-send" aria-hidden="true"></i>{t(lang, 'hub.remit.link')}</a>
  </section>

  <a href="/en/albania/" class="country-switch-banner">
    <span class="fi fi-al" aria-hidden="true"></span>
    <div><p class="country-switch-title">Albania</p><p class="country-switch-sub">Banks, mortgages and loans in Albania →</p></div>
    <i class="ti ti-chevron-right" aria-hidden="true"></i>
  </a>

  <p class="country-disclaimer"><i class="ti ti-shield" aria-hidden="true"></i>{t(lang, 'country.disclaimer')}</p>
</Base>
