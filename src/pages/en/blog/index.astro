---
import Base from '../../../layouts/Base.astro';
import { getPostsByLang } from '../../../data/blog-posts';

export const prerender = true;
const lang = 'en' as const;
const posts = getPostsByLang('en');
---
<Base
  title="Financial Blog — Albanian Banks, Mortgages and Salaries | leku.al"
  description="Articles about personal finance, Albanian banks, mortgages, loans and salaries. Practical financial advice for Albania and Kosovo."
  keywords="Albania financial blog, Albanian banks guide, Albania mortgage blog, Kosovo finance, personal finance Albania"
  lang={lang}
  currentPath="/blog"
>
  <div class="section-header">
    <h1 class="page-title">Financial Blog</h1>
    <p class="page-subtitle">Practical articles on finance, banking and the Albanian economy</p>
  </div>

  <div class="blog-grid">
    {posts.map(post => (
      <a href={`/en/blog/${post.slug}`} class="blog-card">
        <div class="blog-card-meta">
          <span class="blog-category">{post.category}</span>
          <span class="blog-date">{new Date(post.date).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <span class="blog-read">{post.readMinutes} min</span>
        </div>
        <h2 class="blog-card-title">{post.title}</h2>
        <p class="blog-card-desc">{post.description}</p>
        <span class="blog-read-more">Read more <i class="ti ti-arrow-right" aria-hidden="true"></i></span>
      </a>
    ))}
  </div>

  <div class="blog-langs">
    <p class="blog-langs-label">Other language:</p>
    <a href="/blog/" class="blog-lang-link">
      <span class="fi fi-al" aria-hidden="true"></span> Blog shqip →
    </a>
  </div>
</Base>
