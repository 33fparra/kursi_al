---
import Base from '../../layouts/Base.astro';
import { fetchRates } from '../../lib/rates';
import { t } from '../../lib/i18n';

export const prerender = true;
const lang = 'en' as const;
const ratesData = await fetchRates();
const rates     = ratesData?.rates ?? {};
const ratesDate = ratesData?.date ?? '';

const PAIRS = [
  { from: 'EUR', to: 'ALL' },
  { from: 'USD', to: 'ALL' },
  { from: 'GBP', to: 'ALL' },
];

function fmtRate(r: number) {
  return new Intl.NumberFormat('en', {
    minimumFractionDigits: 2, maximumFractionDigits: 2
  }).format(r);
}
---
<Base
  title="leku.al — Simple finance for Albania and Kosovo"
  description="Convert currencies, compare banks, calculate mortgages and net salary. Albanian financial tools — free and instant."
  keywords="leku al, Albania finance, Albanian banks, exchange rate, Albania mortgage, Albanian currency"
  lang={lang}
  currentPath="/"
>

  <div class="lp-hero">

    <!-- Text first (mobile: top, desktop: left) -->
    <div class="lp-hero-text">
      <p class="lp-eyebrow">
        <i class="ti ti-shield-check" aria-hidden="true"></i>
        European Central Bank data · Free · No registration
      </p>

      <h1 class="lp-h1">
        Simple finance<br class="lp-break"/>
        <span class="lp-h1-accent">for Albanians</span>
      </h1>

      <p class="lp-tagline">
        Convert currencies, compare banks, calculate mortgages and net salary —
        all free, no registration, no fees.
      </p>
    </div>

    <!-- SVG after text (mobile: bottom, desktop: right) -->
    <div class="lp-hero-visual" aria-hidden="true">
      <img src="/money-stack.svg" alt="" class="lp-hero-svg" width="220" height="174" loading="eager" decoding="async" />
    </div>

  </div>

  <div class="lp-cards" role="list">

    <a href="/en/albania/" class="lp-card" role="listitem">
      <div class="lp-card-top">
        <span class="fi fi-al lp-card-flag" aria-hidden="true"></span>
        <span class="lp-card-tag">Financial tools</span>
      </div>
      <h2 class="lp-card-title">Albania</h2>
      <p class="lp-card-desc">Banks, mortgages, loans and salaries — with the Albanian tax system.</p>
      <ul class="lp-card-list">
        <li><i class="ti ti-building-bank" aria-hidden="true"></i> 6 banks · rates from 5.5%/yr</li>
        <li><i class="ti ti-home" aria-hidden="true"></i> Mortgage and loan calculator</li>
        <li><i class="ti ti-wallet" aria-hidden="true"></i> Gross → net salary · tax system</li>
        <li><i class="ti ti-notebook" aria-hidden="true"></i> Financial blog</li>
      </ul>
      <span class="lp-card-cta">Explore tools <i class="ti ti-arrow-right" aria-hidden="true"></i></span>
    </a>

    <a href="/en/kosova/" class="lp-card" role="listitem">
      <div class="lp-card-top">
        <span class="fi fi-xk lp-card-flag" aria-hidden="true"></span>
        <span class="lp-card-tag">Financial tools</span>
      </div>
      <h2 class="lp-card-title">Kosovo</h2>
      <p class="lp-card-desc">Banks, mortgages, loans and salaries — TAK system, Euro currency.</p>
      <ul class="lp-card-list">
        <li><i class="ti ti-building-bank" aria-hidden="true"></i> 5 banks · rates from 4.5%/yr</li>
        <li><i class="ti ti-home" aria-hidden="true"></i> Mortgage and loan in EUR</li>
        <li><i class="ti ti-wallet" aria-hidden="true"></i> Gross → net salary · TAK system</li>
        <li><i class="ti ti-notebook" aria-hidden="true"></i> Bilingual financial blog</li>
      </ul>
      <span class="lp-card-cta">Explore tools <i class="ti ti-arrow-right" aria-hidden="true"></i></span>
    </a>

    <a href="/en/kursi" class="lp-card lp-card--converter" role="listitem">
      <div class="lp-card-top">
        <div class="lp-card-icon" aria-hidden="true"><i class="ti ti-arrows-up-down"></i></div>
        <span class="lp-card-tag lp-card-tag--blue">Live rates</span>
      </div>
      <h2 class="lp-card-title">Converter</h2>
      <p class="lp-card-desc">EUR, USD, GBP, CHF vs Albanian lek — updated every day from the ECB.</p>

      {Object.keys(rates).length > 0 ? (
        <ul class="lp-card-rates">
          {PAIRS.map(({ from, to }) => (
            <li class="lp-card-rate-row">
              <span class="lp-rate-pair">1 {from}</span>
              <span class="lp-rate-sep">=</span>
              <span class="lp-rate-val">{fmtRate(rates[`${from}_${to}`] ?? 0)} L</span>
            </li>
          ))}
          {ratesDate && <li class="lp-rate-date"><i class="ti ti-clock" aria-hidden="true"></i> {ratesDate}</li>}
        </ul>
      ) : (
        <ul class="lp-card-list">
          <li><i class="ti ti-arrows-up-down" aria-hidden="true"></i> EUR / ALL · USD / ALL</li>
          <li><i class="ti ti-chart-line" aria-hidden="true"></i> 30-day history chart</li>
          <li><i class="ti ti-send" aria-hidden="true"></i> Remittance calculator</li>
        </ul>
      )}

      <span class="lp-card-cta lp-card-cta--blue">Convert now <i class="ti ti-arrow-right" aria-hidden="true"></i></span>
    </a>

  </div>

  <div class="lp-trust">
    <div class="lp-trust-item"><i class="ti ti-shield-check" aria-hidden="true"></i><span>European Central Bank</span></div>
    <div class="lp-trust-dot" aria-hidden="true"></div>
    <div class="lp-trust-item"><i class="ti ti-refresh" aria-hidden="true"></i><span>Updated daily</span></div>
    <div class="lp-trust-dot" aria-hidden="true"></div>
    <div class="lp-trust-item"><i class="ti ti-lock-off" aria-hidden="true"></i><span>Free · No registration</span></div>
    <div class="lp-trust-dot" aria-hidden="true"></div>
    <div class="lp-trust-item"><i class="ti ti-device-mobile" aria-hidden="true"></i><span>Mobile-first</span></div>
  </div>

</Base>

<style>
.lp-hero { display: flex; flex-direction: column; align-items: center; gap: var(--space-6); padding: var(--space-8) 0 var(--space-6); text-align: center; }
@media (min-width: 640px) { .lp-hero { flex-direction: row; align-items: center; text-align: left; gap: var(--space-10); padding: var(--space-12) 0 var(--space-8); } }
.lp-hero-text { flex: 1; min-width: 0; }
.lp-hero-visual { display: flex; justify-content: center; align-items: center; flex-shrink: 0; }
.lp-hero-svg { width: 140px; height: auto; display: block; animation: lp-float 3s ease-in-out infinite; }
@media (min-width: 640px) { .lp-hero-svg { width: 220px; } }
@media (min-width: 900px) { .lp-hero-svg { width: 260px; } }
@keyframes lp-float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
@media (max-width: 639px) { .lp-eyebrow { justify-content: center; } .lp-tagline { margin-left: auto; margin-right: auto; } }
.lp-eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); font-weight: 500; color: var(--blue-info); background: var(--red-soft); padding: 5px 14px; border-radius: 99px; margin-bottom: var(--space-6); border: 1px solid rgba(37,99,235,0.2); }
.lp-h1 { font-family: 'Instrument Serif', Georgia, serif; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 400; color: var(--ink); line-height: 1.12; letter-spacing: -0.02em; margin-bottom: var(--space-5); }
.lp-h1-accent { color: var(--blue-info); }
.lp-break { display: none; }
@media (min-width: 480px) { .lp-break { display: block; } }
.lp-tagline { font-size: clamp(1rem, 2vw, 1.15rem); color: var(--ink-secondary); line-height: 1.65; max-width: 540px; }
.lp-cards { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin-bottom: var(--space-10); }
@media (min-width: 640px) { .lp-cards { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); } }
.lp-card { display: flex; flex-direction: column; padding: var(--space-6); background: var(--bg-card); border-radius: 16px; border: 1.5px solid var(--border-light); text-decoration: none; transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease; box-shadow: 0 1px 4px rgba(15,23,42,0.05); }
.lp-card:hover { border-color: var(--blue-info); box-shadow: 0 4px 24px rgba(37,99,235,0.12); transform: translateY(-2px); }
.lp-card-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-5); }
.lp-card-flag { width: 40px !important; height: 30px !important; border-radius: 4px; box-shadow: 0 1px 4px rgba(0,0,0,0.15); background-size: cover !important; }
.lp-card-icon { width: 40px; height: 30px; background: var(--red-soft); color: var(--blue-info); border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
.lp-card-tag { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted); background: var(--bg-input); padding: 3px 10px; border-radius: 99px; }
.lp-card-tag--blue { color: var(--blue-info); background: var(--red-soft); }
.lp-card-title { font-family: 'Instrument Serif', Georgia, serif; font-size: 1.5rem; font-weight: 400; color: var(--ink); margin-bottom: var(--space-2); }
.lp-card-desc { font-size: var(--text-small); color: var(--ink-secondary); line-height: 1.55; margin-bottom: var(--space-5); }
.lp-card-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); margin-bottom: var(--space-6); flex: 1; }
.lp-card-list li { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--ink-secondary); }
.lp-card-list .ti { color: var(--blue-info); font-size: 14px; flex-shrink: 0; }
.lp-card-rates { list-style: none; display: flex; flex-direction: column; gap: 2px; margin-bottom: var(--space-6); flex: 1; background: var(--bg-input); border-radius: 10px; padding: var(--space-3) var(--space-4); }
.lp-card-rate-row { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-small); padding: 3px 0; }
.lp-rate-pair { color: var(--ink-muted); font-size: var(--text-xs); min-width: 36px; }
.lp-rate-sep  { color: var(--ink-muted); font-size: var(--text-xs); }
.lp-rate-val  { font-family: 'Instrument Serif', Georgia, serif; font-size: 1rem; color: var(--ink); margin-left: auto; }
.lp-rate-date { font-size: 10px; color: var(--ink-muted); display: flex; align-items: center; gap: 4px; margin-top: var(--space-1); padding-top: var(--space-2); border-top: 1px solid var(--border-light); }
.lp-card-cta { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-small); font-weight: 600; color: var(--blue-info); margin-top: auto; }
.lp-trust { display: flex; align-items: center; justify-content: center; gap: var(--space-4); flex-wrap: wrap; padding: var(--space-5) 0; border-top: 1px solid var(--border-light); }
.lp-trust-item { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--ink-muted); }
.lp-trust-item .ti { color: var(--blue-info); font-size: 15px; }
.lp-trust-dot { width: 3px; height: 3px; background: var(--border-medium); border-radius: 50%; }
@media (max-width: 480px) { .lp-trust-dot { display: none; } }
</style>
