---
import Base from '../../layouts/Base.astro';
import SalaryCalc from '../../components/SalaryCalc';
import { t } from '../../lib/i18n';
import kosovoData from '../../data/kosovo.json';

export const prerender = true;
const lang = 'sq' as const;
const { salary } = kosovoData;
const professions = kosovoData.professions as any[];
---
<Base
  title="Pagat dhe Tatimi në Kosovë — Bruto në Neto 2025 | leku.al"
  description="Llogarit pagën neto nga bruto sipas sistemit tatimor të Kosovës (ATK). Shiko pagat mesatare sipas profesionit. Paga minimale: €400/muaj."
  keywords="pagat kosove, tatimi paga kosove, paga bruto neto kosove, paga minimale kosove, pagat sipas profesionit kosove, ATK tatimi"
  lang={lang}
  currentPath="/kosova/paga"
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/kosova" class="breadcrumb-link">
      <span class="fi fi-xk" aria-hidden="true"></span> Kosova
    </a>
    <i class="ti ti-chevron-right breadcrumb-sep" aria-hidden="true"></i>
    <span class="breadcrumb-current">{t(lang, 'country.salary')}</span>
  </nav>

  <div class="section-header">
    <h1 class="page-title">{t(lang, 'salary.title')}</h1>
    <p class="page-subtitle">{t(lang, 'salary.subtitle.xk')}</p>
  </div>

  <!-- Calculator FIRST -->
  <SalaryCalc
    client:load
    country="xk"
    currency="EUR"
    lang={lang}
    minWage={salary.minWage}
    avgWage={salary.avgWage}
    professions={professions}
  />

  <!-- Tax brackets — secondary -->
  <div class="tax-brackets-card">
    <h2 class="tax-brackets-title">Fashët tatimore (mujore) — Kosova (ATK)</h2>
    <p style="font-size: var(--text-xs); color: var(--ink-muted); margin-bottom: var(--space-3);">Trashësia tatimore zbatohet mbi bazën imponuese (bruto − Trusti 5%). + Pension 5% punëdhënësi.</p>
    <div class="tax-brackets-list">
      {salary.brackets.map(b => (
        <div class="tax-bracket-row">
          <span class="tax-bracket-range">€{b.from} – {b.to ? '€' + b.to : '∞'}</span>
          <span class={`tax-bracket-rate tax-bracket-rate--${b.rate === 0 ? 'zero' : b.rate < 0.08 ? 'mid' : 'high'}`}>
            {b.label}
          </span>
        </div>
      ))}
    </div>
  </div>

  <section class="faq-section">
    <h2 class="faq-title">{t(lang, 'salary.faq.title')}</h2>
    <dl class="faq-list">
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'salary.faq.q1.xk')}</dt>
        <dd class="faq-answer">{t(lang, 'salary.faq.a1.xk')}</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'salary.faq.q2.xk')}</dt>
        <dd class="faq-answer">{t(lang, 'salary.faq.a2.xk')}</dd>
      </div>
    </dl>
  </section>

  <div class="country-tool-nav">
    <a href="/kosova/bankat" class="tool-nav-link">
      <i class="ti ti-building-bank" aria-hidden="true"></i> Krahasim bankash →
    </a>
    <a href="/kosova" class="tool-nav-link">
      <i class="ti ti-arrow-left" aria-hidden="true"></i> Të gjitha mjetet →
    </a>
  </div>
</Base>
