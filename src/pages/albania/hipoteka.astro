---
import Base from '../../layouts/Base.astro';
import MortgageCalc from '../../components/MortgageCalc';
import { t } from '../../lib/i18n';
import albaniaData from '../../data/albania.json';

export const prerender = true;
const lang = 'sq' as const;
const banks = albaniaData.banks as any[];
const lastUpdatedAL = (albaniaData as any)["_____LAST_UPDATE_DATE_____"] ?? null;

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: t(lang, 'mortgage.faq.q1'), acceptedAnswer: { '@type': 'Answer', text: t(lang, 'mortgage.faq.a1') } },
    { '@type': 'Question', name: t(lang, 'mortgage.faq.q2'), acceptedAnswer: { '@type': 'Answer', text: t(lang, 'mortgage.faq.a2') } },
    { '@type': 'Question', name: 'Cila bankë jep normën më të ulët hipotekare në Shqipëri?', acceptedAnswer: { '@type': 'Answer', text: 'Raiffeisen Bank Albania ofron normën më konkurruese me 5.50% vjetore, ndjekur nga BKT me 5.75% dhe OTP Bank me 5.90%. Normat mund të ndryshojnë sipas profileve dhe negocimit.' } },
    { '@type': 'Question', name: 'Sa vjet mund të zgjasë hipoteka në Shqipëri?', acceptedAnswer: { '@type': 'Answer', text: 'Hipotekat në Shqipëri zakonisht ofrohen me afat nga 5 deri në 30 vjet. Afati 20–25 vjeçar është ekuilibri optimal — këste të menaxhueshme dhe interes total i arsyeshëm.' } },
  ],
});

const loanJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LoanOrCredit',
  '@id': 'https://leku.al/albania/hipoteka#loan',
  name: 'Hipoteka Shqipëri — Krahasim Bankash',
  loanType: 'Mortgage',
  currency: 'ALL',
  amount: {
    '@type': 'MonetaryAmount',
    minValue: 1000000,
    maxValue: 50000000,
    currency: 'ALL',
  },
  loanTerm: {
    '@type': 'QuantitativeValue',
    minValue: 5,
    maxValue: 30,
    unitCode: 'ANN',
  },
  annualPercentageRate: {
    '@type': 'QuantitativeValue',
    minValue: 5.5,
    maxValue: 6.5,
    unitCode: 'P1',
  },
  provider: { '@type': 'Organization', name: 'Bankat Shqiptare', url: 'https://leku.al/albania/bankat' },
  feesAndCommissionsSpecification: 'Norma vjetore e interesit 5.5%–6.5%. Komision administrimi sipas bankës. Sigurim prone i detyrueshëm.',
  description: 'Krahasim i normave të hipotekës për bankat kryesore shqiptare: Raiffeisen, BKT, OTP Bank, Tirana Bank, Credins dhe ProCredit.',
});

const howToJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'Si të llogaritni këstët mujore të hipotekës në Shqipëri',
  description: 'Llogaritni këstët mujore, interesin total dhe koston totale të hipotekës sipas bankës dhe afatit.',
  totalTime: 'PT2M',
  tool: [{ '@type': 'HowToTool', name: 'Kalkulatore hipoteke leku.al' }],
  step: [
    { '@type': 'HowToStep', position: 1, name: 'Vendosni shumën e huasë', text: 'Shkruani shumën e hipotekës në lekë ose euro në fushën e parë.' },
    { '@type': 'HowToStep', position: 2, name: 'Zgjidhni bankën', text: 'Klikoni mbi bankën e preferuar — norma do të plotësohet automatikisht.' },
    { '@type': 'HowToStep', position: 3, name: 'Zgjidhni afatin', text: 'Zgjidhni afatin e dëshiruar (5, 10, 15, 20, 25 ose 30 vjet).' },
    { '@type': 'HowToStep', position: 4, name: 'Shikoni rezultatin', text: 'Kalkulatori llogarit menjëherë këstët mujore, totalin e paguar dhe interesin total.' },
  ],
});
---
<Base
  title="Kalkulatore Hipoteke Shqipëri — Llogarit Këstët Mujore | leku.al"
  description="Llogarit këstët mujore të hipotekës për bankat shqiptare. Krahaso Raiffeisen, BKT, OTP, Tirana Bank. Norma nga 5.5% vjetore."
  keywords="kalkulatore hipoteke, hipoteka shqipëri, keste mujore hipoteke, norma hipoteke 2025, raiffeisen hipoteke, BKT hipoteke"
  lang={lang}
  currentPath="/albania/hipoteka/"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={faqJsonLd} />
    <script is:inline type="application/ld+json" set:html={loanJsonLd} />
    <script is:inline type="application/ld+json" set:html={howToJsonLd} />
  </Fragment>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/albania/" class="breadcrumb-link">
      <span class="fi fi-al" aria-hidden="true"></span> Shqipëria
    </a>
    <i class="ti ti-chevron-right breadcrumb-sep" aria-hidden="true"></i>
    <span class="breadcrumb-current">{t(lang, 'country.mortgage')}</span>
  </nav>

  <div class="section-header">
    <h1 class="page-title">{t(lang, 'mortgage.title')}</h1>
    <p class="page-subtitle">{t(lang, 'mortgage.subtitle.al')}</p>
    <p class="page-intro">Hipotekat në Shqipëri ofrohen në ALL dhe EUR. Normat vjetore luhaten nga 5.5% tek 6.5% sipas bankës dhe afatit. Llogarisni këstët mujore dhe koston totale para se të vendosni.</p>
  </div>

  <MortgageCalc client:load banks={banks} currency="ALL" lang={lang} />

  <section class="faq-section">
    <h2 class="faq-title">{t(lang, 'mortgage.faq.title')}</h2>
    <dl class="faq-list">
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'mortgage.faq.q1')}</dt>
        <dd class="faq-answer">{t(lang, 'mortgage.faq.a1')}</dd>
      </div>
      <div class="faq-item">
        <dt class="faq-question">{t(lang, 'mortgage.faq.q2')}</dt>
        <dd class="faq-answer">{t(lang, 'mortgage.faq.a2')}</dd>
      </div>
    </dl>
  </section>

  <div class="country-tool-nav">
    <a href="/albania/bankat/" class="tool-nav-link">
      <i class="ti ti-building-bank" aria-hidden="true"></i> Krahasim bankash →
    </a>
    <a href="/albania/kredia/" class="tool-nav-link">
      <i class="ti ti-credit-card" aria-hidden="true"></i> Kredi personale →
    </a>
  </div>
  
  <p class="page-last-updated">
    <i class="ti ti-refresh" aria-hidden="true"></i>
    {lastUpdatedAL}
  </p>
</Base>
