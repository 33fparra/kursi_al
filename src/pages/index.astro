---
import Base from '../layouts/Base.astro';
import { fetchRates } from '../lib/rates';
import { t } from '../lib/i18n';

export const prerender = true;
const lang = 'sq' as const;
const ratesData = await fetchRates();
const rates     = ratesData?.rates ?? {};
const ratesDate = ratesData?.date ?? '';

const PAIRS = [
  { from: 'EUR', to: 'ALL' },
  { from: 'USD', to: 'ALL' },
  { from: 'GBP', to: 'ALL' },
];

function fmtRate(r: number) {
  return new Intl.NumberFormat('sq-AL', {
    minimumFractionDigits: 2, maximumFractionDigits: 2
  }).format(r);
}
---
<Base
  title="leku.al — Financa të thjeshta për Shqipërinë dhe Kosovën"
  description="Konverto valuta, krahaso bankat, llogarit hipotekën dhe pagën. Mjetet financiare shqiptare — falas dhe menjëherë."
  keywords="leku al, financat shqipëri, bankat shqiptare, kursi valutor, hipoteka shqipëri"
  lang={lang}
  currentPath="/"
>

  <!-- ══ HERO ══ -->
  <div class="lp-hero">

    <!-- Text FIRST on mobile and desktop left -->
    <div class="lp-hero-text">
      <p class="lp-eyebrow">
        <i class="ti ti-shield-check" aria-hidden="true"></i>
        Të dhëna nga Banka Qendrore Europiane · Falas · Pa regjistrim
      </p>

      <h1 class="lp-h1">
        Financa të thjeshta<br class="lp-break"/>
        <span class="lp-h1-accent">për shqiptarët</span>
      </h1>

      <p class="lp-tagline">
        Konverto valuta, krahaso bankat, llogarit hipotekën dhe pagën neto —
        gjithçka falas, pa regjistrim, pa komisione.
      </p>
    </div>

    <!-- SVG AFTER text: on mobile = below titles, on desktop = right column -->
    <div class="lp-hero-visual" aria-hidden="true">
      <img
        src="/money-stack.svg"
        alt=""
        class="lp-hero-svg"
        width="220"
        height="174"
        loading="eager"
        decoding="async"
      />
    </div>

  </div>

  <!-- ══ THREE OPTION CARDS ══ -->
  <div class="lp-cards" role="list">

    <!-- Albania -->
    <a href="/albania/" class="lp-card" role="listitem">
      <div class="lp-card-top">
        <span class="fi fi-al lp-card-flag" aria-hidden="true"></span>
        <span class="lp-card-tag">Mjetet financiare</span>
      </div>
      <h2 class="lp-card-title">Shqipëria</h2>
      <p class="lp-card-desc">Bankat, hipotekat, kreditë dhe pagat — me tatimin shqiptar.</p>
      <ul class="lp-card-list" aria-label="Çfarë ka">
        <li><i class="ti ti-building-bank" aria-hidden="true"></i> 6 banka · norma nga 5.5%/vit</li>
        <li><i class="ti ti-home" aria-hidden="true"></i> Kalkulatore hipoteke dhe kredie</li>
        <li><i class="ti ti-wallet" aria-hidden="true"></i> Paga bruto → neto · sistemi tatimor</li>
        <li><i class="ti ti-notebook" aria-hidden="true"></i> Blog financiar shqiptar</li>
      </ul>
      <span class="lp-card-cta">
        Hap mjetet <i class="ti ti-arrow-right" aria-hidden="true"></i>
      </span>
    </a>

    <!-- Kosovo -->
    <a href="/kosova/" class="lp-card" role="listitem">
      <div class="lp-card-top">
        <span class="fi fi-xk lp-card-flag" aria-hidden="true"></span>
        <span class="lp-card-tag">Mjetet financiare</span>
      </div>
      <h2 class="lp-card-title">Kosova</h2>
      <p class="lp-card-desc">Bankat, hipotekat, kreditë dhe pagat — sistemi i ATK-së, monedha Euro.</p>
      <ul class="lp-card-list" aria-label="Çfarë ka">
        <li><i class="ti ti-building-bank" aria-hidden="true"></i> 5 banka · norma nga 4.5%/vit</li>
        <li><i class="ti ti-home" aria-hidden="true"></i> Hipoteka dhe kredi në Euro</li>
        <li><i class="ti ti-wallet" aria-hidden="true"></i> Paga bruto → neto · sistemi ATK</li>
        <li><i class="ti ti-notebook" aria-hidden="true"></i> Blog financiar dygjuhësh</li>
      </ul>
      <span class="lp-card-cta">
        Hap mjetet <i class="ti ti-arrow-right" aria-hidden="true"></i>
      </span>
    </a>

    <!-- Converter -->
    <a href="/kursi/" class="lp-card lp-card--converter" role="listitem">
      <div class="lp-card-top">
        <div class="lp-card-icon" aria-hidden="true">
          <i class="ti ti-arrows-up-down"></i>
        </div>
        <span class="lp-card-tag lp-card-tag--blue">Kurs sot</span>
      </div>
      <h2 class="lp-card-title">Konvertuesi</h2>
      <p class="lp-card-desc">Kurset e këmbimit EUR, USD, GBP, CHF kundrejt lekës — të përditësuara çdo ditë.</p>

      {Object.keys(rates).length > 0 ? (
        <ul class="lp-card-rates" aria-label="Kurset e sotit">
          {PAIRS.map(({ from, to }) => (
            <li class="lp-card-rate-row">
              <span class="lp-rate-pair">1 {from}</span>
              <span class="lp-rate-sep">=</span>
              <span class="lp-rate-val">{fmtRate(rates[`${from}_${to}`] ?? 0)} L</span>
            </li>
          ))}
          {ratesDate && <li class="lp-rate-date"><i class="ti ti-clock" aria-hidden="true"></i> {ratesDate}</li>}
        </ul>
      ) : (
        <ul class="lp-card-list">
          <li><i class="ti ti-arrows-up-down" aria-hidden="true"></i> EUR / ALL · USD / ALL</li>
          <li><i class="ti ti-arrows-up-down" aria-hidden="true"></i> GBP / ALL · CHF / ALL</li>
          <li><i class="ti ti-chart-line" aria-hidden="true"></i> Historiku 30 ditë</li>
          <li><i class="ti ti-send" aria-hidden="true"></i> Kalkulatore remitancash</li>
        </ul>
      )}

      <span class="lp-card-cta lp-card-cta--blue">
        Konverto tani <i class="ti ti-arrow-right" aria-hidden="true"></i>
      </span>
    </a>

  </div>

  <!-- ══ TRUST BAR ══ -->
  <div class="lp-trust" aria-label="Informacion rreth shërbimit">
    <div class="lp-trust-item">
      <i class="ti ti-shield-check" aria-hidden="true"></i>
      <span>Banka Qendrore Europiane</span>
    </div>
    <div class="lp-trust-dot" aria-hidden="true"></div>
    <div class="lp-trust-item">
      <i class="ti ti-refresh" aria-hidden="true"></i>
      <span>Përditësohet çdo ditë</span>
    </div>
    <div class="lp-trust-dot" aria-hidden="true"></div>
    <div class="lp-trust-item">
      <i class="ti ti-lock-off" aria-hidden="true"></i>
      <span>Falas · Pa regjistrim</span>
    </div>
    <div class="lp-trust-dot" aria-hidden="true"></div>
    <div class="lp-trust-item">
      <i class="ti ti-device-mobile" aria-hidden="true"></i>
      <span>Mobile-first</span>
    </div>
  </div>

</Base>

<style>
/* ── Landing page — all styles scoped ── */

/* ── Hero layout ── */
.lp-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-6);
  padding: var(--space-8) 0 var(--space-6);
  text-align: center;
}

/* Desktop: two columns — text left, SVG right */
@media (min-width: 640px) {
  .lp-hero {
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: var(--space-10);
    padding: var(--space-12) 0 var(--space-8);
  }
}

.lp-hero-text {
  flex: 1;
  min-width: 0;
}

/* Mobile: SVG first (above text), centered */
.lp-hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  /* DOM order: after text → on mobile below text, on desktop right column ✓ */
}

.lp-hero-svg {
  width: 140px;
  height: auto;
  display: block;
  animation: lp-float 3s ease-in-out infinite;
}

@media (min-width: 640px) {
  .lp-hero-svg {
    width: 220px;
  }
}

@media (min-width: 900px) {
  .lp-hero-svg {
    width: 260px;
  }
}

@keyframes lp-float {
  0%, 100% { transform: translateY(0px);  }
  50%       { transform: translateY(-8px); }
}

/* On mobile, eyebrow/tagline centered */
@media (max-width: 639px) {
  .lp-eyebrow { justify-content: center; }
  .lp-tagline { margin-left: auto; margin-right: auto; }
}

.lp-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--blue-info);
  background: var(--red-soft);
  padding: 5px 14px;
  border-radius: 99px;
  margin-bottom: var(--space-6);
  border: 1px solid rgba(37,99,235,0.2);
}

.lp-h1 {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: clamp(2.2rem, 5vw, 3.8rem);
  font-weight: 400;
  color: var(--ink);
  line-height: 1.12;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-5);
}

.lp-h1-accent {
  color: var(--blue-info);
}

.lp-break { display: none; }
@media (min-width: 480px) { .lp-break { display: block; } }

.lp-tagline {
  font-size: clamp(1rem, 2vw, 1.15rem);
  color: var(--ink-secondary);
  line-height: 1.65;
  max-width: 540px;
  margin-bottom: 0;
}

/* ── Cards grid ── */
.lp-cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-4);
  margin-bottom: var(--space-10);
}

@media (min-width: 640px) {
  .lp-cards { grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
}

.lp-card {
  display: flex;
  flex-direction: column;
  padding: var(--space-6);
  background: var(--bg-card);
  border-radius: 16px;
  border: 1.5px solid var(--border-light);
  text-decoration: none;
  transition: border-color 150ms ease, box-shadow 150ms ease, transform 150ms ease;
  box-shadow: 0 1px 4px rgba(15,23,42,0.05);
  position: relative;
  overflow: hidden;
}

.lp-card:hover {
  border-color: var(--blue-info);
  box-shadow: 0 4px 24px rgba(37,99,235,0.12);
  transform: translateY(-2px);
}

.lp-card--converter {
  border-color: var(--border-medium);
}
.lp-card--converter:hover {
  border-color: var(--blue-info);
}

.lp-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-5);
}

.lp-card-flag {
  width: 40px !important;
  height: 30px !important;
  border-radius: 4px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.15);
  background-size: cover !important;
}

.lp-card-icon {
  width: 40px; height: 30px;
  background: var(--red-soft);
  color: var(--blue-info);
  border-radius: 4px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}

.lp-card-tag {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-muted);
  background: var(--bg-input);
  padding: 3px 10px;
  border-radius: 99px;
}

.lp-card-tag--blue {
  color: var(--blue-info);
  background: var(--red-soft);
}

.lp-card-title {
  font-family: 'Instrument Serif', Georgia, serif;
  font-size: 1.5rem;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: var(--space-2);
  letter-spacing: -0.01em;
}

.lp-card-desc {
  font-size: var(--text-small);
  color: var(--ink-secondary);
  line-height: 1.55;
  margin-bottom: var(--space-5);
}

/* Feature list */
.lp-card-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-bottom: var(--space-6);
  flex: 1;
}

.lp-card-list li {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  color: var(--ink-secondary);
}

.lp-card-list .ti {
  color: var(--blue-info);
  font-size: 14px;
  flex-shrink: 0;
}

/* Rate list (converter card) */
.lp-card-rates {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: var(--space-6);
  flex: 1;
  background: var(--bg-input);
  border-radius: 10px;
  padding: var(--space-3) var(--space-4);
}

.lp-card-rate-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-small);
  padding: 3px 0;
}

.lp-rate-pair { color: var(--ink-muted); font-size: var(--text-xs); min-width: 36px; }
.lp-rate-sep  { color: var(--ink-muted); font-size: var(--text-xs); }
.lp-rate-val  { font-family: 'Instrument Serif', Georgia, serif; font-size: 1rem; font-weight: 400; color: var(--ink); margin-left: auto; }
.lp-rate-date { font-size: 10px; color: var(--ink-muted); display: flex; align-items: center; gap: 4px; margin-top: var(--space-1); padding-top: var(--space-2); border-top: 1px solid var(--border-light); }

/* CTA link */
.lp-card-cta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-small);
  font-weight: 600;
  color: var(--blue-info);
  margin-top: auto;
}

.lp-card-cta--blue { color: var(--blue-info); }

/* ── Trust bar ── */
.lp-trust {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  flex-wrap: wrap;
  padding: var(--space-5) 0;
  border-top: 1px solid var(--border-light);
  margin-top: var(--space-2);
}

.lp-trust-item {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-xs);
  color: var(--ink-muted);
}

.lp-trust-item .ti {
  color: var(--blue-info);
  font-size: 15px;
}

.lp-trust-dot {
  width: 3px; height: 3px;
  background: var(--border-medium);
  border-radius: 50%;
}

@media (max-width: 480px) {
  .lp-trust-dot { display: none; }
  .lp-trust { gap: var(--space-3); justify-content: flex-start; }
}
</style>
