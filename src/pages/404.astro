---
export const prerender = true;
---
<!doctype html>
<html lang="sq" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Duke punuar për ju — leku.al</title>
  <meta name="robots" content="noindex" />

  <link rel="icon" href="/logo.svg" type="image/svg+xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css"
  />

  <script is:inline>
    const t = localStorage.getItem('kursi-theme') ||
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    document.documentElement.setAttribute('data-theme', t);
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    }

    .page {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      background: #0f172a;
    }

    /* Background image */
    .page-bg {
      position: absolute;
      inset: 0;
      background-image: url('/404.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      opacity: 0.35;
    }

    /* Gradient overlay so text is always readable */
    .page-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(15, 23, 42, 0.55) 0%,
        rgba(15, 23, 42, 0.80) 100%
      );
    }

    /* Content card */
    .card {
      position: relative;
      z-index: 10;
      text-align: center;
      padding: 48px 32px;
      max-width: 480px;
      width: 90%;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.20);
      border-radius: 99px;
      padding: 6px 16px;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fcd34d;
      margin-bottom: 24px;
    }

    .title {
      font-family: 'Instrument Serif', Georgia, serif;
      font-size: clamp(2rem, 8vw, 3.25rem);
      font-weight: 700;
      color: #ffffff;
      line-height: 1.15;
      margin-bottom: 16px;
    }

    .subtitle {
      font-size: 1rem;
      color: rgba(255,255,255,0.72);
      line-height: 1.6;
      margin-bottom: 36px;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #2563eb;
      color: #ffffff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9375rem;
      font-weight: 600;
      padding: 14px 28px;
      border-radius: 10px;
      text-decoration: none;
      transition: background 150ms ease, transform 100ms ease;
      min-height: 48px;
    }
    .btn-back:hover  { background: #1d4ed8; }
    .btn-back:active { transform: scale(0.97); }

    .logo {
      margin-bottom: 32px;
    }
    .logo img {
      height: 32px;
      width: auto;
      filter: brightness(0) invert(1);
      opacity: 0.9;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="page-bg" aria-hidden="true"></div>
    <div class="page-overlay" aria-hidden="true"></div>

    <div class="card">
      <div class="logo">
        <a href="/">
          <img src="/logo.svg" alt="leku.al" />
        </a>
      </div>

      <div class="badge">
        <i class="ti ti-tools" aria-hidden="true"></i>
        Në ndërtim
      </div>

      <h1 class="title">Jemi duke punuar<br />për ju.</h1>

      <p class="subtitle">
        Kjo faqe është ende në ndërtim.<br />
        Do të jetë gati së shpejti — faleminderit për durimin tuaj!
      </p>

      <a href="/" class="btn-back">
        <i class="ti ti-arrow-left" aria-hidden="true"></i>
        Kthehu në faqen kryesore
      </a>
    </div>
  </div>
</body>
</html>
