---
import { t } from '../lib/i18n';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entry: CollectionEntry<'ditari'>;
  lang?: 'sq' | 'en';
}

const { entry, lang = 'sq' } = Astro.props;
const { title, description, type, category, date, image, imageAlt, readMinutes } = entry.data;

const slug = entry.id.split('/').pop()!.replace(/^\d{4}-\d{2}-\d{2}-/, '');
const base = lang === 'en' ? '/en/ditari' : '/ditari';
const href = `${base}/artikull/${type}/${slug}`;

const typeLabel = type === 'edukim' ? t(lang, 'ditari.typeEdukim') : t(lang, 'ditari.typeLajme');
const locale = lang === 'en' ? 'en-GB' : 'sq-AL';
const dateLabel = date.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
---
<a href={href} class="ditari-card">
  <div class="ditari-card-img-wrap">
    <img src={image} alt={imageAlt} class="ditari-card-img" loading="lazy" width="400" height="225" />
    <span class={`ditari-badge ditari-badge--${type}`}>{typeLabel}</span>
  </div>
  <div class="ditari-card-body">
    <div class="ditari-card-meta">
      <span class="blog-category">{category}</span>
      <span class="blog-date">{dateLabel}</span>
      <span class="blog-read">{readMinutes} {t(lang, 'ditari.minRead')}</span>
    </div>
    <h2 class="ditari-card-title">{title}</h2>
    <p class="ditari-card-desc">{description}</p>
    <span class="blog-read-more">{t(lang, 'ditari.readMore')} <i class="ti ti-arrow-right" aria-hidden="true"></i></span>
  </div>
</a>
