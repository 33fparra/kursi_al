---
import { t, localePath } from '../lib/i18n';
import LangSwitch from '../components/LangSwitch';

export interface Props {
  title: string;
  description?: string;
  lang?: 'sq' | 'en' | 'it' | 'el';
  currentPath?: string;
}

const {
  title,
  description = t('sq', 'index.meta.description'),
  lang = 'sq',
  currentPath = '/',
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Alternate hreflang links for SEO -->
    <link rel="alternate" hreflang="sq" href={`https://kursi.al${currentPath}`} />
    <link rel="alternate" hreflang="en" href={`https://kursi.al/en${currentPath === '/' ? '' : currentPath}`} />
    <link rel="alternate" hreflang="it" href={`https://kursi.al/it${currentPath === '/' ? '' : currentPath}`} />
    <link rel="alternate" hreflang="el" href={`https://kursi.al/el${currentPath === '/' ? '' : currentPath}`} />
    <link rel="alternate" hreflang="x-default" href={`https://kursi.al${currentPath}`} />

    <!-- Anti-flash: MUST run before any CSS to avoid dark-mode flicker -->
    <script is:inline>
      const t = localStorage.getItem('kursi-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
    </script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap"
      rel="stylesheet"
    />

    <!-- Tabler Icons -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.31.0/dist/tabler-icons.min.css"
    />
  </head>
  <body>
    <nav class="nav" role="navigation" aria-label="Navigimi kryesor">
      <a href={localePath(lang, '/')} class="nav-logo" aria-label="kursi.al">
        kursi<span>.</span>al
      </a>

      <ul class="nav-links" role="list">
        <li>
          <a
            href={localePath(lang, '/')}
            class:list={['nav-link', { 'nav-link--active': currentPath === '/' }]}
          >{t(lang, 'nav.converter')}</a>
        </li>
        <li>
          <a
            href={localePath(lang, '/historiku')}
            class:list={['nav-link', { 'nav-link--active': currentPath === '/historiku' }]}
          >{t(lang, 'nav.history')}</a>
        </li>
        <li>
          <a
            href={localePath(lang, '/remitanca')}
            class:list={['nav-link', { 'nav-link--active': currentPath === '/remitanca' }]}
          >{t(lang, 'nav.remittance')}</a>
        </li>
        <li>
          <a
            href={localePath(lang, '/tabela')}
            class:list={['nav-link', { 'nav-link--active': currentPath === '/tabela' }]}
          >{t(lang, 'nav.table')}</a>
        </li>
      </ul>

      <div class="nav-controls">
        <LangSwitch client:load currentLang={lang} pathname={pathname} />
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Ndrysho temën"
          title="Modaliteti i errët / i ndritshëm"
        >
          <i class="ti ti-sun theme-toggle__icon theme-toggle__icon--light" aria-hidden="true"></i>
          <i class="ti ti-moon theme-toggle__icon theme-toggle__icon--dark" aria-hidden="true"></i>
        </button>
      </div>
    </nav>

    <main class="main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="footer" role="contentinfo">
      <div class="container">
        <p class="footer-text">
          <i class="ti ti-info-circle" aria-hidden="true"></i>
          {t(lang, 'footer.disclaimer')}
          <a
            href="https://www.frankfurter.app"
            class="footer-link"
            target="_blank"
            rel="noopener noreferrer">Frankfurter API</a>
          {t(lang, 'footer.sourceSuffix')}
        </p>
        <p class="footer-copy">© 2026 kursi.al</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('theme-toggle');
      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('kursi-theme', next);
      });
    </script>
  </body>
</html>

<style is:global>
  /* ─── Design Tokens ─── */
  :root {
    --red-albania:   #e41e20;
    --red-dark:      #b01519;
    --red-soft:      #fbeaea;
    --ink:           #1a1a1a;
    --ink-secondary: #4a4a4a;
    --ink-muted:     #888888;
    --bg-page:       #f7f6f3;
    --bg-card:       #ffffff;
    --bg-input:      #f2f1ee;
    --border-light:  #e8e6e1;
    --border-medium: #cccac5;
    --green-result:  #1a6b3c;
    --green-soft:    #eaf3de;
    --green-trend:   #2e7d52;
    --blue-info:     #1a5fa5;
    --blue-soft:     #e6f1fb;
    --text-display: 2.5rem;
    --text-h1:      1.75rem;
    --text-h2:      1.25rem;
    --text-h3:      1rem;
    --text-body:    1rem;
    --text-small:   0.875rem;
    --text-xs:      0.75rem;
    --weight-normal: 400;
    --weight-medium: 500;
    --weight-bold:   700;
    --space-1:   4px; --space-2:   8px; --space-3:  12px; --space-4:  16px;
    --space-5:  20px; --space-6:  24px; --space-8:  32px; --space-10: 40px;
    --space-12: 48px; --space-16: 64px;
    --container-max: 480px;
    --container-pad: var(--space-5);
    --radius-sm: 6px; --radius-md: 10px; --radius-lg: 14px; --radius-xl: 20px;
    --transition-fast: 150ms ease; --transition-normal: 250ms ease;
  }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme='light']) {
      --red-albania:   #f03032; --red-dark:      #c41e20; --red-soft:      #2d1515;
      --ink:           #f0efeb; --ink-secondary: #b8b6b0; --ink-muted:     #7a7875;
      --bg-page:       #141412; --bg-card:       #1e1d1a; --bg-input:      #2a2926;
      --border-light:  #2e2d2a; --border-medium: #3e3d3a;
      --green-result:  #4ade80; --green-soft:    #0f2a1a; --green-trend:   #3abf6a;
      --blue-info:     #60a5fa; --blue-soft:     #0f1f35;
    }
  }

  [data-theme='dark'] {
    --red-albania:   #f03032; --red-dark:      #c41e20; --red-soft:      #2d1515;
    --ink:           #f0efeb; --ink-secondary: #b8b6b0; --ink-muted:     #7a7875;
    --bg-page:       #141412; --bg-card:       #1e1d1a; --bg-input:      #2a2926;
    --border-light:  #2e2d2a; --border-medium: #3e3d3a;
    --green-result:  #4ade80; --green-soft:    #0f2a1a; --green-trend:   #3abf6a;
    --blue-info:     #60a5fa; --blue-soft:     #0f1f35;
  }

  [data-theme='light'] {
    --red-albania:   #e41e20; --red-dark:      #b01519; --red-soft:      #fbeaea;
    --ink:           #1a1a1a; --ink-secondary: #4a4a4a; --ink-muted:     #888888;
    --bg-page:       #f7f6f3; --bg-card:       #ffffff; --bg-input:      #f2f1ee;
    --border-light:  #e8e6e1; --border-medium: #cccac5;
    --green-result:  #1a6b3c; --green-soft:    #eaf3de; --green-trend:   #2e7d52;
    --blue-info:     #1a5fa5; --blue-soft:     #e6f1fb;
  }

  /* ─── Reset ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: var(--text-body);
    color: var(--ink);
    background: var(--bg-page);
    line-height: 1.5;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }
  a { color: inherit; text-decoration: none; }
  :focus-visible {
    outline: 2px solid var(--red-albania);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .sr-only {
    position: absolute; width: 1px; height: 1px; padding: 0;
    margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  /* ─── Nav ─── */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--container-pad);
    background: var(--bg-card);
    border-bottom: 1px solid var(--border-light);
    position: sticky;
    top: 0;
    z-index: 100;
    gap: var(--space-3);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    flex-shrink: 0;
  }
  .nav-logo span { color: var(--red-albania); }
  .nav-links {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    overflow-x: auto;
    -ms-overflow-style: none;
    scrollbar-width: none;
    flex: 1;
  }
  .nav-links::-webkit-scrollbar { display: none; }
  .nav-link {
    font-size: var(--text-small);
    color: var(--ink-secondary);
    white-space: nowrap;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  .nav-link:hover, .nav-link--active { color: var(--red-albania); border-color: var(--red-albania); }
  .nav-controls { display: flex; align-items: center; gap: var(--space-2); flex-shrink: 0; }

  /* ─── Lang Switch ─── */
  .lang-switch { display: flex; gap: 3px; }
  .lang-btn {
    background: transparent;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    padding: 4px 7px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: var(--weight-medium);
    color: var(--ink-secondary);
    cursor: pointer;
    min-height: 32px;
    min-width: 32px;
    transition: all var(--transition-fast);
    line-height: 1;
  }
  .lang-btn:hover { border-color: var(--red-albania); color: var(--red-albania); }
  .lang-btn--active {
    background: var(--red-soft);
    border-color: var(--red-albania);
    color: var(--red-albania);
    font-weight: var(--weight-bold);
  }

  /* ─── Theme Toggle ─── */
  .theme-toggle {
    background: var(--bg-input);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--ink-secondary);
    transition: background var(--transition-fast), color var(--transition-fast);
    flex-shrink: 0;
  }
  .theme-toggle:hover { background: var(--border-light); color: var(--ink); }
  [data-theme='dark']  .theme-toggle__icon--dark,
  [data-theme='light'] .theme-toggle__icon--light,
  :root:not([data-theme]) .theme-toggle__icon--light { display: none; }

  /* ─── Layout ─── */
  .main { flex: 1; padding: var(--space-6) 0 var(--space-12); }
  .container { max-width: var(--container-max); margin: 0 auto; padding: 0 var(--container-pad); }

  /* ─── Footer ─── */
  .footer { border-top: 1px solid var(--border-light); padding: var(--space-6) 0; background: var(--bg-card); }
  .footer .container { display: flex; flex-direction: column; gap: var(--space-2); }
  .footer-text { font-size: var(--text-xs); color: var(--ink-muted); display: flex; align-items: center; gap: var(--space-1); flex-wrap: wrap; }
  .footer-link { color: var(--blue-info); text-decoration: underline; text-underline-offset: 2px; }
  .footer-copy { font-size: var(--text-xs); color: var(--ink-muted); }

  /* ─── Typography ─── */
  .page-title { font-family: 'Playfair Display', serif; font-size: var(--text-h1); font-weight: 700; color: var(--ink); margin-bottom: var(--space-2); }
  .page-subtitle { font-size: var(--text-small); color: var(--ink-secondary); margin-bottom: var(--space-6); }
  .section-header { margin-bottom: var(--space-6); }
  .update-info { font-size: var(--text-xs); color: var(--ink-muted); display: flex; align-items: center; gap: var(--space-1); margin-top: var(--space-3); }

  /* ─── Rate Badge ─── */
  .rate-badge {
    display: inline-flex; align-items: center; gap: var(--space-2);
    background: var(--blue-soft); color: var(--blue-info);
    font-size: var(--text-xs); font-weight: var(--weight-medium);
    padding: 6px 12px; border-radius: var(--radius-sm);
  }

  /* ─── Converter Card ─── */
  .converter-card { background: var(--bg-card); border-radius: var(--radius-xl); border: 1px solid var(--border-light); padding: var(--space-6); margin-bottom: var(--space-4); }
  .currency-block { background: var(--bg-input); border-radius: var(--radius-lg); padding: var(--space-5); margin-bottom: var(--space-3); }
  .currency-block--result { background: var(--green-soft); border: 1px solid rgba(26,107,60,0.15); margin-bottom: 0; }
  .currency-label { font-size: var(--text-xs); font-weight: var(--weight-medium); color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: var(--space-2); display: flex; align-items: center; gap: var(--space-2); }
  .amount-input { background: transparent; border: none; padding: 0; font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--ink); width: 100%; outline: none; line-height: 1.2; }
  .amount-input::placeholder { color: var(--ink-muted); }
  .currency-select { margin-top: var(--space-2); background: transparent; border: none; font-family: 'DM Sans', sans-serif; font-size: var(--text-small); font-weight: var(--weight-medium); color: var(--ink-secondary); cursor: pointer; padding: 0; outline: none; width: 100%; appearance: none; -webkit-appearance: none; }
  .currency-select option { background: var(--bg-card); color: var(--ink); }
  .result-amount { font-family: 'Playfair Display', serif; font-size: var(--text-display); font-weight: 700; color: var(--green-result); line-height: 1.1; transition: opacity var(--transition-fast); word-break: break-all; }
  .result-amount--loading { opacity: 0.4; }
  .swap-btn {
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; background: var(--bg-card);
    border: 1px solid var(--border-medium); border-radius: 50%;
    cursor: pointer; color: var(--ink-secondary); margin: var(--space-1) auto;
    transition: background var(--transition-fast), border-color var(--transition-fast), color var(--transition-fast), transform var(--transition-normal);
  }
  .swap-btn:hover { background: var(--red-soft); border-color: var(--red-albania); color: var(--red-albania); transform: rotate(180deg); }
  .converter-meta { display: flex; align-items: center; justify-content: space-between; margin-top: var(--space-4); flex-wrap: wrap; gap: var(--space-2); }

  /* ─── Quick amounts ─── */
  .quick-amounts { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-2); margin-top: var(--space-4); }
  .quick-btn { background: var(--bg-input); border: 1px solid var(--border-light); border-radius: var(--radius-sm); padding: 10px 4px; text-align: center; font-family: 'DM Sans', sans-serif; font-size: var(--text-small); font-weight: var(--weight-medium); color: var(--ink-secondary); cursor: pointer; transition: all var(--transition-fast); min-height: 44px; }
  .quick-btn:hover, .quick-btn--active { background: var(--red-soft); border-color: var(--red-albania); color: var(--red-albania); }

  /* ─── Remittance Banner ─── */
  .remit-banner { background: var(--green-soft); border-radius: var(--radius-lg); padding: var(--space-4) var(--space-5); display: flex; justify-content: space-between; align-items: center; border: 1px solid rgba(26,107,60,0.12); transition: background var(--transition-fast); text-decoration: none; margin-top: var(--space-4); }
  .remit-banner:hover { background: #daeece; }
  .remit-title { font-size: var(--text-small); font-weight: var(--weight-medium); color: var(--green-result); display: flex; align-items: center; gap: var(--space-2); }
  .remit-sub { font-size: var(--text-xs); color: var(--green-trend); margin-top: 2px; }

  /* ─── Rates Table ─── */
  .rates-summary { margin-top: var(--space-8); }
  .rates-summary-title { font-size: var(--text-small); font-weight: var(--weight-medium); color: var(--ink-secondary); margin-bottom: var(--space-3); display: flex; align-items: center; gap: var(--space-2); }
  .rates-table { width: 100%; border-collapse: collapse; background: var(--bg-card); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border-light); font-size: var(--text-small); }
  .rates-table th { font-size: var(--text-xs); font-weight: var(--weight-medium); color: var(--ink-muted); text-align: left; padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border-light); text-transform: uppercase; letter-spacing: 0.06em; }
  .rates-table td { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--border-light); }
  .rates-table tr:last-child td { border-bottom: none; }
  .rates-table .pair { font-weight: var(--weight-medium); color: var(--ink); }
  .rates-table .rate-val { font-family: 'Playfair Display', serif; font-weight: 600; color: var(--ink); text-align: right; }
  .change-positive { color: var(--green-trend); }
  .change-negative { color: #c0392b; }
  .change-neutral  { color: var(--ink-muted); }
  .rates-table--full th, .rates-table--full td { padding: var(--space-4); }

  /* ─── Btn primary ─── */
  .btn-primary { background: var(--red-albania); color: #fff; font-family: 'DM Sans', sans-serif; font-size: var(--text-body); font-weight: var(--weight-medium); padding: 14px 24px; border-radius: var(--radius-md); border: none; width: 100%; cursor: pointer; transition: background var(--transition-fast), transform 100ms ease; min-height: 48px; }
  .btn-primary:hover  { background: var(--red-dark); }
  .btn-primary:active { transform: scale(0.98); }

  /* ─── Pair selector (historiku) ─── */
  .pair-selector { display: flex; gap: var(--space-2); flex-wrap: wrap; margin-bottom: var(--space-4); }
  .pair-btn { background: var(--bg-input); border: 1px solid var(--border-light); border-radius: var(--radius-sm); padding: 8px 14px; font-family: 'DM Sans', sans-serif; font-size: var(--text-small); font-weight: var(--weight-medium); color: var(--ink-secondary); cursor: pointer; transition: all var(--transition-fast); min-height: 44px; }
  .pair-btn:hover, .pair-btn--active { background: var(--red-soft); border-color: var(--red-albania); color: var(--red-albania); }

  /* ─── Chart card ─── */
  .chart-card { background: var(--bg-card); border-radius: var(--radius-xl); border: 1px solid var(--border-light); padding: var(--space-5); }
  .chart-placeholder { text-align: center; padding: 48px 0; color: var(--ink-muted); }
  .chart-placeholder i { font-size: 24px; display: block; margin-bottom: 8px; }
  .chart-stats { display: flex; gap: var(--space-4); margin-bottom: var(--space-5); flex-wrap: wrap; }
  .stat-item { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 80px; }
  .stat-label { font-size: var(--text-xs); color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .stat-value { font-family: 'Playfair Display', serif; font-size: var(--text-h3); font-weight: 700; color: var(--ink); display: flex; flex-direction: column; }
  .stat-value--high { color: var(--green-trend); }
  .stat-value--low  { color: #c0392b; }
  .stat-date { font-family: 'DM Sans', sans-serif; font-size: var(--text-xs); font-weight: var(--weight-normal); color: var(--ink-muted); }

  /* ─── Remittance rows ─── */
  .remit-table-wrap { display: flex; flex-direction: column; gap: var(--space-3); }
  .remit-row { background: var(--bg-card); border-radius: var(--radius-lg); border: 1px solid var(--border-light); padding: var(--space-4) var(--space-5); transition: border-color var(--transition-fast); }
  .remit-row--best { border-color: var(--green-trend); background: var(--green-soft); }
  .remit-row-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-3); gap: var(--space-3); flex-wrap: wrap; }
  .remit-provider-name { font-weight: var(--weight-medium); color: var(--ink); font-size: var(--text-body); }
  .remit-tag { display: inline-block; padding: 2px 8px; border-radius: 99px; font-size: var(--text-xs); font-weight: var(--weight-medium); margin-left: var(--space-2); }
  .tag-green { background: var(--green-soft);  color: var(--green-result); }
  .tag-blue  { background: var(--blue-soft);   color: var(--blue-info); }
  .tag-muted { background: var(--bg-input);    color: var(--ink-muted); }
  .tag-best  { background: var(--green-result); color: #fff; }
  .remit-details { display: flex; flex-direction: column; gap: var(--space-2); }
  .remit-detail-row { display: flex; justify-content: space-between; font-size: var(--text-small); color: var(--ink-secondary); padding: var(--space-1) 0; }
  .remit-detail-row--total { border-top: 1px solid var(--border-light); margin-top: var(--space-1); padding-top: var(--space-2); font-weight: var(--weight-medium); color: var(--ink); }
  .remit-arrives { font-family: 'Playfair Display', serif; font-weight: 700; }
  .remit-arrives--best { font-family: 'Playfair Display', serif; font-weight: 700; color: var(--green-result); }

  /* ─── Affiliate buttons ─── */
